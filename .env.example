# Development Environment Variables
# Copy this file to .env and modify as needed

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Authentication
BETTER_AUTH_SECRET=your_secret_key_here
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# SmartOLT API Configuration
SMARTOLT_SUBDOMAIN=your-subdomain
SMARTOLT_API_KEY=your-api-key-here
NEXT_PUBLIC_SMARTOLT_SUBDOMAIN=your-subdomain

# Caching Configuration
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Map Configuration
NEXT_PUBLIC_DEFAULT_LATITUDE=-6.2088
NEXT_PUBLIC_DEFAULT_LONGITUDE=106.8456
NEXT_PUBLIC_DEFAULT_ZOOM=11

# Real-time Configuration
NEXT_PUBLIC_WS_URL=ws://localhost:3001
WEBSOCKET_PORT=3001

# Monitoring Configuration
ALERT_CHECK_INTERVAL=30000
DASHBOARD_REFRESH_INTERVAL=30000
CACHE_TTL=60